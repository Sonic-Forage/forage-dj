# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtualenv
.venv/
venv/
ENV/
env/

# UV
.uv/

# Models & large assets (cache locally)
models/
*.safetensors
*.bin

# User cache (real path — tilde does not work in gitignore)
.foragedj/
# Also catch the literal ~/.foragedj if someone creates it by mistake
**/.foragedj/

# Hugging Face / torch hub caches (heavy)
.cache/huggingface/
.huggingface/
torch_hub/

# Audio (generated tracks are huge — keep only tiny test fixtures)
*.wav
*.mp3
*.flac
*.ogg
!test_*.wav
!fixtures/*.wav

# IDE / tools
.idea/
.vscode/
*.swp
.ruff_cache/
.mypy_cache/

# OS
.DS_Store
Thumbs.db

# Grok session state (keep the plan + important notes, ignore temp artifacts)
.grok/tmp/
.grok/logs/
.grok/agent-outputs/
.grok/session-logs/
.grok/hf-token.env   # never commit your HF token

checkpoints/

# Generated
generated/
logs/
